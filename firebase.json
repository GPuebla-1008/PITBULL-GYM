{
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**/!(*.apk)",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/flutter_service_worker.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "sw.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "**/*.apk",
        "headers": [
          {
            "key": "Content-Disposition",
            "value": "attachment"
          },
          {
            "key": "Content-Type",
            "value": "application/vnd.android.package-archive"
          }
        ]
      }
    ]
  }
}
